{
  "name": "localpro-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "node scripts/seed-settings.mjs",
    "start": "next start",
    "lint": "next lint",
    "db:reset": "node --env-file=.env.local scripts/db-reset.mjs",
    "db:seed": "node --env-file=.env.local scripts/db-reset.mjs --seed-only",
    "db:seed:no-admin": "node --env-file=.env.local scripts/db-reset.mjs --seed-only --no-admin",
    "db:seed-categories": "node --env-file=.env.local scripts/seed-categories.mjs",
    "db:seed-categories:wipe": "node --env-file=.env.local scripts/seed-categories.mjs --wipe",
    "db:seed-settings": "node --env-file=.env.local scripts/seed-settings.mjs",
    "db:seed-settings:force": "node --env-file=.env.local scripts/seed-settings.mjs --force",
    "db:seed-skills": "node --env-file=.env.local scripts/seed-skills.mjs",
    "db:seed-skills:force": "node --env-file=.env.local scripts/seed-skills.mjs --force",
    "db:seed-skills:wipe": "node --env-file=.env.local scripts/seed-skills.mjs --wipe",
    "db:migrate-skills": "node --env-file=.env.local scripts/migrate-skills.mjs",
    "icons:generate": "node scripts/generate-icons.mjs",
    "og:generate": "node scripts/generate-og-image.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.43.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.99.2",
