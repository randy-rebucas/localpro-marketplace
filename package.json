    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.4.3",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "cookie": "^0.6.0",
    "dompurify": "^3.4.0",
    "driver.js": "^1.4.0",
    "isomorphic-dompurify": "^3.9.0",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.575.0",
    "marked": "^17.0.3",
    "mongoose": "^8.4.0",
    "next": "16.2.4",
    "next-themes": "^0.4.0",
    "openai": "^6.25.0",
    "pino": "^9.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.4.1",
    "react-phone-number-input": "^3.4.16",
    "recharts": "^2.12.7",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "twilio": "^5.12.2",
    "use-places-autocomplete": "^4.0.1",
    "web-push": "^3.6.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/dompurify": "^3.2.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.0.1",
    "postcss": "^8",
    "sharp": "^0.34.5",
