# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Use two DIFFERENT long random strings (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-secret

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Transactional email is sent via Resend (https://resend.com).
# NOTE: SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS are NOT used by this app.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender address shown in the From: header — must be verified in Resend dashboard.
SMTP_FROM=LocalPro <noreply@localpro.app>

# ─── PayMongo ─────────────────────────────────────────────────────────────────
PAYMONGO_SECRET_KEY=sk_test_xxxx
PAYMONGO_WEBHOOK_SECRET=whsec_xxxx

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxx

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Google Maps ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ─── Google Tag Manager ──────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ─── SEO / Webmaster verification (optional) ─────────────────────────────────
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-token
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-token

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Random secret to authenticate cron job requests
CRON_SECRET=change-me-to-a-long-random-string

# ─── PWA Web Push (VAPID) ─────────────────────────────────────────────────────
# Generate keys once with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is exposed to the browser (safe to commit after generation)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
# Email address shown in VAPID contact header (no mailto: prefix needed here)
VAPID_SUBJECT=admin@localpro.ph

# ─── Sentry (error tracking — required in production) ────────────────────────
# Create project at https://sentry.io → Settings → Projects → DSN
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
# Auth token for uploading source maps during CI builds (optional locally)
# https://sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=sntryu_xxx
# Organisation and project slugs (used by withSentryConfig in next.config.ts)
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# ─── Upstash Redis (distributed rate limiting & JWT revocation) ───────────────
# Create a database at https://console.upstash.com/ → Copy REST URL and token
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── PayPal ───────────────────────────────────────────────────────────────────
# Create app at https://developer.paypal.com/dashboard/applications/
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# Register a webhook in PayPal dashboard → Webhooks, then paste the Webhook ID here
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
# "sandbox" for development / testing, "live" for production
# Server-only (do not prefix with NEXT_PUBLIC_ — this controls live/sandbox mode)
PAYPAL_MODE=sandbox

# ─── Admin / Support email ────────────────────────────────────────────────────
# Receives deletion request alerts and other admin notifications
ADMIN_SUPPORT_EMAIL=support@localpro.asia

# ─── Facebook OAuth ───────────────────────────────────────────────────────────
# Create an app at https://developers.facebook.com/
# Add "Facebook Login" product; set Valid OAuth Redirect URI to:
#   https://yourdomain.com/api/auth/facebook/callback
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── Twilio (SMS OTP via Verify API) ─────────────────────────────────────────
# Sign up at https://www.twilio.com/ → create a Verify Service to get the SID
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxx

# ─── Internal URL (used by middleware for token refresh) ───────────────────────
# Set this to http://localhost:3000 in development, or your production domain.
# Required when running behind a proxy/tunnel (ngrok, Vercel, etc.) so the
# proxy can call /api/auth/refresh directly on localhost instead of the public URL.
NEXT_INTERNAL_URL=http://localhost:3000
